{
    "editor.formatOnSave": false,
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "search.exclude": {
        "out": true,
        "**/node_modules": true,
        ".vscode-test": true
    },
    "tslint.autoFixOnSave": true,
    "tslint.ignoreDefinitionFiles": true,
    "prettier.tabWidth": 4,
    "prettier.useTabs": false,
    "prettier.printWidth": 150,
    "leetnotion.editor.shortcuts": [
        "submit",
        "star",
        "solution",
        "description",
        "test",
        "submissions"
    ],
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#61d3b5",
        "activityBar.background": "#61d3b5",
        "activityBar.foreground": "#15202b",
        "activityBar.inactiveForeground": "#15202b99",
        "activityBarBadge.background": "#ad50ce",
        "activityBarBadge.foreground": "#e7e7e7",
        "commandCenter.border": "#15202b99",
        "sash.hoverBorder": "#61d3b5",
        "statusBar.background": "#39c8a2",
        "statusBar.foreground": "#15202b",
        "statusBarItem.hoverBackground": "#2da182",
        "statusBarItem.remoteBackground": "#39c8a2",
        "statusBarItem.remoteForeground": "#15202b",
        "titleBar.activeBackground": "#39c8a2",
        "titleBar.activeForeground": "#15202b",
        "titleBar.inactiveBackground": "#39c8a299",
        "titleBar.inactiveForeground": "#15202b99"
    },
    "peacock.color": "#39c8a2"
}
